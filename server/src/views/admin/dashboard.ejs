<% var chart = typeof dashboardChart !== "undefined" && dashboardChart ? dashboardChart : { labels: [], values: [] }; %>
<% if (typeof queryForbidden !== "undefined" && queryForbidden) { %>
<div class="alert alert-warning shadow-sm mb-3" role="alert">
  Bạn không có quyền truy cập mục đó.
</div>
<% } %>

<div class="row g-3 mb-3">
  <div class="col-6 col-xl">
    <div class="card shadow-sm h-100 border admin-dashboard-kpi">
      <div class="card-body py-3">
        <div class="text-body-secondary small">Blog</div>
        <div class="fs-5 fw-semibold text-body"><%= chart.values[0] != null ? chart.values[0] : 0 %></div>
        <a href="/admin/blog" class="small link-secondary text-decoration-none stretched-link">Quản lý bài viết</a>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl">
    <div class="card shadow-sm h-100 border admin-dashboard-kpi">
      <div class="card-body py-3">
        <div class="text-body-secondary small">Liên hệ KH</div>
        <div class="fs-5 fw-semibold text-body"><%= chart.values[1] != null ? chart.values[1] : 0 %></div>
        <a href="/admin/contact?type=customer" class="small link-secondary text-decoration-none stretched-link">Xem tin</a>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl">
    <div class="card shadow-sm h-100 border admin-dashboard-kpi">
      <div class="card-body py-3">
        <div class="text-body-secondary small">Liên hệ đối tác</div>
        <div class="fs-5 fw-semibold text-body"><%= chart.values[2] != null ? chart.values[2] : 0 %></div>
        <a href="/admin/contact/partner" class="small link-secondary text-decoration-none stretched-link">Xem tin</a>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl">
    <div class="card shadow-sm h-100 border admin-dashboard-kpi">
      <div class="card-body py-3">
        <div class="text-body-secondary small">Dịch vụ</div>
        <div class="fs-5 fw-semibold text-body"><%= chart.values[3] != null ? chart.values[3] : 0 %></div>
        <a href="/admin/service" class="small link-secondary text-decoration-none stretched-link">Danh sách</a>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl">
    <div class="card shadow-sm h-100 border admin-dashboard-kpi">
      <div class="card-body py-3">
        <div class="text-body-secondary small">Help center</div>
        <div class="fs-5 fw-semibold text-body"><%= chart.values[4] != null ? chart.values[4] : 0 %></div>
        <a href="/admin/help-center/article" class="small link-secondary text-decoration-none stretched-link">Bài viết</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-12">
    <div class="card shadow-sm border">
      <div class="card-header bg-body-secondary bg-opacity-10 border-bottom py-3">
        <strong class="fw-semibold">Tổng quan nhanh</strong>
        <div class="small text-body-secondary mt-1 mb-0">Cùng dữ liệu với các ô số phía trên (khi tải trang).</div>
      </div>
      <div class="card-body pt-3">
        <div class="admin-dash-chart-wrap">
          <canvas id="adminDashboardBarChart" width="400" height="260" aria-label="Biểu đồ cột tổng quan" role="img"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="admin-dashboard-chart-json"><%- JSON.stringify(chart) %></script>
<script>
  (function () {
    function initAdminDashboardChart() {
      var el = document.getElementById("admin-dashboard-chart-json");
      var payload = { labels: [], values: [] };
      try {
        payload = JSON.parse(el ? el.textContent : "{}");
      } catch (e) {}

      var canvas = document.getElementById("adminDashboardBarChart");
      if (!canvas || typeof Chart === "undefined") return;

      var styles = getComputedStyle(document.documentElement);
      var primaryRgb = styles.getPropertyValue("--cui-primary-rgb").trim();
      if (!primaryRgb) primaryRgb = "88, 86, 214";

      var muted = "rgba(" + primaryRgb + ", 0.22)";
      var barBorder = "rgba(" + primaryRgb + ", 0.55)";
      var gridRgb = styles.getPropertyValue("--cui-border-color-rgb").trim() || "207, 212, 222";
      var tick = styles.getPropertyValue("--cui-body-color").trim() || "#323a49";
      var tickSec = styles.getPropertyValue("--cui-secondary-color").trim() || "#6d7d9c";

      var n = (payload.labels && payload.labels.length) ? payload.labels.length : 0;
      var fills = [];
      for (var i = 0; i < n; i++) fills.push(muted);

      new Chart(canvas.getContext("2d"), {
        type: "bar",
        data: {
          labels: payload.labels || [],
          datasets: [
            {
              label: "Số lượng",
              data: payload.values || [],
              backgroundColor: fills,
              borderColor: barBorder,
              borderWidth: 1,
              borderRadius: 4,
              maxBarThickness: 56,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  var v = ctx.parsed && ctx.parsed.y != null ? ctx.parsed.y : 0;
                  return " " + Number(v).toLocaleString("vi-VN");
                },
              },
            },
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: { color: tick, maxRotation: 0, autoSkip: true },
            },
            y: {
              beginAtZero: true,
              ticks: {
                precision: 0,
                color: tickSec,
              },
              grid: {
                color: "rgba(" + gridRgb + ", 0.25)",
              },
            },
          },
        },
      });
    }

    document.addEventListener("admin:charts-ready", initAdminDashboardChart, { once: true });
  })();
</script>
