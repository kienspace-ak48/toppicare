<div class="flex justify-between items-center">
  <h2 class="font-bold">Customize section/ Tùy chỉnh cấu hình web <i class="text-blue-500 hover:cursor-pointer fa-regular fa-circle-question hover:scale-150"></i></h2>
  <button
    id="btn_cta_save_config"
    class="font-bold px-4 py-3 rounded-lg border border-gray-300 bg-blue-500 text-white"
  >
    Save config
  </button>
</div>
<!-- page info -->
<section id="pageinfo" >
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <!-- Email -->
  <div>
    <label class="form-label font-medium">Email</label>
    <input
      type="text"
      name="pageinfo_email"
      value="<%=data?.customize?.email||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="admin@gmail.com"
    />
  </div>

  <!-- Phone -->
  <div>
    <label class="form-label font-medium">Phone number</label>
    <input
      type="text"
      name="pageinfo_phone"
      value="<%=data?.customize?.phone||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="19001900"
    />
  </div>

  <!-- Zalo -->
  <div>
    <label class="form-label font-medium">Zalo</label>
    <input
      type="text"
      name="pageinfo_zalo"
      value="<%=data?.customize?.zalo||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="19001900"
    />
  </div>

  <!-- Address -->
  <div>
    <label class="form-label font-medium">Address</label>
    <input
      type="text"
      name="pageinfo_address"
      value="<%=data?.customize?.address||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
    />
  </div>

  <!-- Facebook -->
  <div>
    <label class="form-label font-medium">Facebook</label>
    <input
      type="text"
      name="pageinfo_facebook"
      value="<%=data?.customize?.facebook||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="https://facebook.com/yourpage"
    />
  </div>

  <!-- TikTok -->
  <div>
    <label class="form-label font-medium">TikTok</label>
    <input
      type="text"
      name="pageinfo_tiktok"
      value="<%=data?.customize?.tiktok||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="https://tiktok.com/@yourpage"
    />
  </div>

  <!-- YouTube -->
  <div>
    <label class="form-label font-medium">YouTube</label>
    <input
      type="text"
      name="pageinfo_youtube"
      value="<%=data?.customize?.youtube||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="https://youtube.com/@yourchannel"
    />
  </div>

  <!-- Footer title -->
  <div>
    <label class="form-label font-medium">Worktime</label>
    <input
      type="text"
      name="worktime"
      value="<%=data?.customize?.worktime||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
      placeholder="Title..."
    />
  </div>

</div>

<hr class="my-6"/>

<!-- SEO Section -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

