<div class="admin-page-toolbar">
  <h1 class="mb-0 h5">
    Tùy chỉnh cấu hình web
    <i class="fa-regular fa-circle-question icon-link-hint ms-1" title="Xem trang chủ" role="button" tabindex="0" onclick="goToActionBlank('/')"></i>
  </h1>
  <button type="button" id="btn_cta_save_config" class="btn btn-primary">Lưu cấu hình</button>
</div>

<section id="pageinfo">
  <div class="card shadow-sm mb-4">
    <div class="card-header">
      <strong>Thông tin liên hệ &amp; mạng xã hội</strong>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_email">Email</label>
          <input
            type="email"
            id="pageinfo_email"
            name="pageinfo_email"
            value="<%=data?.customize?.email||''%>"
            class="form-control"
            placeholder="admin@gmail.com"
            autocomplete="email"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_phone">Điện thoại</label>
          <input
            type="text"
            id="pageinfo_phone"
            name="pageinfo_phone"
            value="<%=data?.customize?.phone||''%>"
            class="form-control"
            placeholder="19001900"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_zalo">Zalo</label>
          <input
            type="text"
            id="pageinfo_zalo"
            name="pageinfo_zalo"
            value="<%=data?.customize?.zalo||''%>"
            class="form-control"
            placeholder="19001900"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_address">Địa chỉ</label>
          <input
            type="text"
            id="pageinfo_address"
            name="pageinfo_address"
            value="<%=data?.customize?.address||''%>"
            class="form-control"
            placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_facebook">Facebook</label>
          <input
            type="url"
            id="pageinfo_facebook"
            name="pageinfo_facebook"
            value="<%=data?.customize?.facebook||''%>"
            class="form-control"
            placeholder="https://facebook.com/yourpage"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_tiktok">TikTok</label>
          <input
            type="url"
            id="pageinfo_tiktok"
            name="pageinfo_tiktok"
            value="<%=data?.customize?.tiktok||''%>"
            class="form-control"
            placeholder="https://tiktok.com/@yourpage"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="pageinfo_youtube">YouTube</label>
          <input
            type="url"
            id="pageinfo_youtube"
            name="pageinfo_youtube"
            value="<%=data?.customize?.youtube||''%>"
            class="form-control"
            placeholder="https://youtube.com/@yourchannel"
          />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="worktime">Giờ làm việc</label>
          <input
            type="text"
            id="worktime"
            name="worktime"
            value="<%=data?.customize?.worktime||''%>"
            class="form-control"
            placeholder="VD: 8:00 – 20:00"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header">
      <strong>SEO &amp; ảnh đại diện</strong>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <label class="form-label" for="webname">Tên website</label>
          <input type="text" id="webname" class="form-control" value="<%=data?.customize?.title||''%>" />
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="keywords">Từ khóa</label>
          <input type="text" id="keywords" class="form-control" value="<%=data?.customize?.keywords||''%>" placeholder="từ khóa, cách nhau dấu phẩy" />
        </div>
        <div class="col-12">
          <label class="form-label" for="desc">Mô tả (meta description)</label>
          <textarea id="desc" class="form-control" rows="3" placeholder="Mô tả ngắn cho SEO"><%=data?.customize?.desc||''%></textarea>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="gtm_id">Google Tag Manager (Container ID)</label>
          <input
            type="text"
            id="gtm_id"
            name="gtm_id"
            class="form-control"
            value="<%=data?.customize?.gtm_id||''%>"
            placeholder="GTM-XXXXXXX"
            autocomplete="off"
          />
          <div class="form-text">Để trống nếu không dùng. Ví dụ: <code>GTM-TR6NW9NQ</code></div>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label" for="meta_pixel_id">Meta (Facebook) Pixel ID</label>
          <input
            type="text"
            id="meta_pixel_id"
            name="meta_pixel_id"
            class="form-control"
            value="<%=data?.customize?.meta_pixel_id||''%>"
            placeholder="vd: 1291350602880286"
            autocomplete="off"
            inputmode="numeric"
          />
          <div class="form-text">Chỉ nhập ID pixel (số). Để trống nếu không dùng. Script <code>fbevents.js</code> + PageView được chèn trên website.</div>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label">Ảnh trang tải app (bên phải, /app)</label>
          <div class="form-text mb-2">Ảnh lớn bên phải trang hướng dẫn tải ứng dụng trên máy tính.</div>
          <div class="image_action admin-image-action-block">
            <div class="d-flex flex-wrap gap-2 align-items-stretch">
              <button type="button" class="btn btn-outline-success chooseImg flex-grow-1">Chọn ảnh</button>
              <input
                type="text"
                name="download_app_img"
                value="<%=data?.customize?.download_app_img||''%>"
                class="form-control img_input flex-grow-1 hidden"
                placeholder="Đường dẫn ảnh"
                autocomplete="off"
              />
            </div>
            <div class="img_preview admin-img-preview mt-2">
              <img
                src="<%= data?.customize?.download_app_img ? '/' + data.customize.download_app_img : '/imgs/img_downloadapp.png' %>"
                alt="Preview ảnh trang tải app"
              />
            </div>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label">Ảnh / favicon site (thư viện)</label>
          <div class="image_action admin-image-action-block">
            <div class="d-flex flex-wrap gap-2 align-items-stretch">
              <button type="button" class="btn btn-outline-success chooseImg flex-grow-1">Chọn ảnh</button>
              <input
                type="text"
                name="website_img"
                value="<%=data?.customize?.img||''%>"
                class="form-control img_input flex-grow-1 hidden"
                placeholder="Đường dẫn ảnh"
              />
            </div>
            <div class="img_preview admin-img-preview mt-2">
              <img src="/<%=data?.customize?.img||''%>" alt="" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div
  id="gallery_modal"
  class="admin-choose-img-modal fixed inset-0 items-center justify-center hidden"
>
  <div class="admin-choose-img-panel">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
      <h5 class="mb-0">Chọn ảnh</h5>
      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="closeChooseImgModal()" aria-label="Đóng">×</button>
    </div>
    <div id="imgList" class="admin-img-picker-grid"></div>
  </div>
</div>

<script>
  var ctaChooseImg = document.querySelectorAll(".chooseImg");
  const chooseImgModal = document.querySelector("#gallery_modal");
  let imgInputIsFocusing = null;

  function openChooseImgModal() {
    chooseImgModal.classList.remove("hidden");
    chooseImgModal.classList.add("flex");
  }
  function closeChooseImgModal() {
    chooseImgModal.classList.remove("flex");
    chooseImgModal.classList.add("hidden");
  }
  ctaChooseImg.forEach((el) => {
    el.addEventListener("click", (ev) => {
      ev.preventDefault();
      loadImage();
      let input = el.closest(".image_action");
      imgInputIsFocusing = input;
      openChooseImgModal();
    });
  });
  function selectImage(src) {
    imgInputIsFocusing.querySelector(".img_input").value = src;
    imgInputIsFocusing.querySelector(".img_preview img").src = "/" + src;
    closeChooseImgModal();
  }

  function loadImage() {
    imgList.innerHTML = "Loading...";
    $.ajax({
      url: "/admin/gallery/image-getall",
      method: "GET",
      success: (res) => {
        if (res.success) {
          imgList.innerHTML = "";
          res.data.forEach((item) => {
            const img = document.createElement("img");
            img.src = "/" + item.path;
            img.className = "admin-img-picker-item";
            img.onclick = () => selectImage(item.path);
            imgList.appendChild(img);
          });
        }
      },
      error: (xhr, status, err) =>
        console.log(xhr.responseJSON?.mess || "Server error"),
    });
  }

  document.getElementById("btn_cta_save_config").addEventListener("click", async () => {
    const data = {
      pageinfo_email: document.querySelector("[name='pageinfo_email']").value,
      pageinfo_phone: document.querySelector("[name='pageinfo_phone']").value,
      pageinfo_zalo: document.querySelector("[name='pageinfo_zalo']").value,
      pageinfo_address: document.querySelector("[name='pageinfo_address']").value,
      pageinfo_facebook: document.querySelector("[name='pageinfo_facebook']").value,
      pageinfo_tiktok: document.querySelector("[name='pageinfo_tiktok']").value,
      pageinfo_youtube: document.querySelector("[name='pageinfo_youtube']").value,
      worktime: document.querySelector("[name='worktime']").value,
      webname: document.getElementById("webname").value,
      desc: document.getElementById("desc").value,
      keywords: document.getElementById("keywords").value,
      gtm_id: document.getElementById("gtm_id").value,
      meta_pixel_id: document.getElementById("meta_pixel_id")?.value || "",
      img: document.querySelector("[name='website_img']").value,
      download_app_img: document.querySelector("[name='download_app_img']")?.value || "",
    };

    const res = await fetch("/admin/page-config/customize-section", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });

    const result = await res.json();
    if (result.success) {
      myNotification("Cập nhật thành công", "success");
    } else {
      myNotification("Cập nhật thất bại", "danger");
    }
  });
</script>
