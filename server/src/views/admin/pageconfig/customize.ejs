  </div>

  <div>
    <label class="font-medium">Keyword</label>
    <input
      type="text"
      id="keywords"
      value="<%=data?.customize?.keywords||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
    />
  </div>

  <!-- <div>
    <label class="font-medium">Google Analytics</label>
    <input
      type="text"
      id="gg_a"
      value="<%#=data?.customize?.gg_a||''%>"
      class="w-full border border-gray-300 rounded-lg px-3 py-2"
    />
  </div> -->

  <!-- <div>
    <label class="font-medium">Google Webmaster Tool</label>
    <input
      type="text"
      id="gg_wt"
      value="<%#=data?.customize?.gg_wt||''%>"
