<style>
  .admin-table-shell {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.05);
    overflow: hidden;
  }
  .admin-table-shell .dt-layout-row {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: space-between !important;
    align-items: center !important;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    background: #fafafa;
    border-bottom: 1px solid #e5e7eb;
  }
  .admin-table-shell .dt-layout-cell:last-child .dt-layout-row {
    border-bottom: none;
    background: #fff;
  }
  .admin-table-shell .dt-search label { display: none !important; }
  .admin-table-shell .dt-search input {
    font-size: 0.875rem;
    padding: 0.375rem 0.625rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    min-width: 11rem;
  }
  .admin-table-shell .dt-layout-cell { width: auto !important; }
  .admin-table-shell table.dataTable { width: 100% !important; margin: 0 !important; }
  .admin-table-shell table.dataTable thead th {
    border-bottom: 1px solid #e5e7eb !important;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }
  .admin-table-shell table.dataTable tbody td {
    border-bottom: 1px solid #f3f4f6 !important;
    vertical-align: middle !important;
    padding: 0.375rem 0.5rem;
  }
  .admin-table-shell .dt-paging { font-size: 0.8125rem; }
  .admin-table-shell table.dataTable tbody tr:hover { background-color: #f9fafb !important; }
  .admin-table-shell .blog-thumb-wrap {
    width: 72px;
    height: 72px;
    max-width: 100%;
    overflow: hidden;
    margin-left: auto;
    margin-right: auto;
    border-radius: 0.375rem;
    border: 1px solid #f3f4f6;
    background: #f9fafb;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .admin-table-shell .blog-thumb-wrap img {
    width: 100%;
    height: 100%;
    max-width: 72px;
    max-height: 72px;
    object-fit: cover;
    display: block;
  }
</style>
<div class="flex flex-wrap justify-between items-center gap-3 mb-4">
  <h1 class="text-base font-semibold text-gray-800 m-0">Help center / Danh sách bài viết</h1>
  <a
    href="/admin/help-center/article/form-add"
    id="btn_cta_add_blog"
    class="inline-flex items-center gap-1 text-sm font-medium text-white no-underline px-3 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 shadow-sm border-0"
  >
    Thêm bài +
  </a>
</div>
<div class="admin-table-shell wrapper_table">
  <table id="blog_tbl" class="w-full text-sm text-gray-700">
    <thead class="bg-gray-50 text-gray-600">
      <tr>
        <th class="px-3 py-2.5 font-semibold text-left">Name</th>
        <th class="px-3 py-2.5 font-semibold text-left">Slug</th>
        <th class="px-3 py-2.5 font-semibold text-center">Image</th>
        <th class="px-3 py-2.5 font-semibold text-center">Show</th>
        <th class="px-3 py-2.5 font-semibold text-center">Action</th>
      </tr>
    </thead>
    <tbody class="bg-white">
    </tbody>
  </table>
</div>

<!-- SCRIPT -->
<script>
  var blogTable = null;
  // blogTable.ajax.reload(null, false);

  blogTable = new DataTable("#blog_tbl", {
    ajax: {
      url: "/admin/help-center/article/get-all",
      dataSrc: "data",
    },
    autoWidth: false,
    ordering: false, // ⭐ QUAN TRỌNG
    layout: {
    topStart: 'pageLength',
    topEnd: 'search',
    bottomStart: null,
    bottomEnd: 'paging'
  },
    info: false,
    columns: [
      { data: "title", render: (v) => `<span class="line-clamp-2 block px-2 py-1 text-sm text-left text-gray-800">${v}</span>` },
      { data: "slug", render: (v) => `<span class="line-clamp-2 block px-2 py-1 text-sm text-left text-gray-600 font-mono">${v}</span>` },
      {
        data: "image_url",
        render: (v, t, r) => {
          const path = (r?.image_url && String(r.image_url).trim()) ? String(r.image_url).replace(/^\/+/, "") : "";
          if (!path) {
            return `<div class="blog-thumb-wrap text-xs text-gray-400">—</div>`;
          }
          return `<div class="blog-thumb-wrap py-0">
            <img src="/${path}" alt="" loading="lazy" decoding="async" />
          </div>`;
        },
      },
      { data: "status", render: (v, type, row) => `${row.status?`<div class="text-center py-1"><i class="fa-regular fa-eye text-gray-700" title="Hiển thị"></i></div>`:`<div class="text-center py-1"><i class="fa-regular fa-eye-slash text-red-500" title="Ẩn"></i></div>`}` },
      {
        data: null,
        render: (data, type, row) =>
          `<div class="flex items-center justify-center gap-4 text-gray-600">
            <a href="/admin/help-center/article/edit/${row._id}" class="hover:text-blue-600" title="Sửa"><i class="fa-solid fa-pen-to-square"></i></a>
            <i role="button" tabindex="0" class="fa-solid fa-trash-can btn_delete_blog cursor-pointer hover:text-red-600" title="Xóa"></i>
          </div>`,
      },
    ],
  });
  //

  const blogTbodyTable = document.querySelector("#blog_tbl tbody");
  blogTbodyTable.addEventListener("click", function (ev) {
    const btnDelete = ev.target.closest(".btn_delete_blog");
    if (!btnDelete) return;

    //lay row hien tai
    const tr = btnDelete.closest("tr");
    const rowData = blogTable.row(tr).data();

    console.log(rowData);
    // alert(rowData._id)
    confirmDelete(rowData._id);
  });
  function deleteBlog(id) {
    fetch(`/admin/help-center/article/delete/${id}`, {
      method: "DELETE",
      headers: {
        "Content-Type": "application/json",
      },
    })
      .then((res) => res.json())
      .then((res) => {
        console.log(res);
        if (res.success) {
          myNotification("delete success", "success");
          blogTable.ajax.reload(null, false);
        }
      })
      .catch((err) => console.log(err));
  }
  //
  function confirmDelete(id) {
    if(!id) return;
    Swal.fire({
      title: "Are you sure?",
      // text: "You won't be able to revert this!",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, delete it!",
    }).then((result) => {
      if (result.isConfirmed) {
        // Swal.fire({
        //   title: "Deleted!",
        //   text: "Your file has been deleted.",
        //   icon: "success"
        // });
        deleteBlog(id);
      }
    });
  }
</script>
