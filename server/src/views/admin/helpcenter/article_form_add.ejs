<script src="/libs/tinymce/tinymce.min.js"></script>

<div class="admin-page-toolbar d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
  <h1 class="mb-0 h5">Help center — Thêm bài viết</h1>
  <button type="button" id="btn_create_blog" class="btn btn-primary">Tạo bài viết</button>
</div>

<div class="row g-3">
  <div class="col-lg-8">
    <div class="card shadow-sm border">
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label" for="hc_add_title">Tiêu đề</label>
          <input type="text" id="hc_add_title" name="title" class="form-control" placeholder="Tiêu đề bài viết" autocomplete="off" />
        </div>
        <div class="mb-3">
          <label class="form-label" for="hc_add_slug">Slug</label>
          <input type="text" id="hc_add_slug" name="slug" class="form-control" placeholder="slug-url" autocomplete="off" />
        </div>
        <div class="mb-3">
          <label class="form-label" for="tags">Thẻ (tags)</label>
          <input type="text" id="tags" class="form-control" placeholder="từ khóa, ngăn cách bằng dấu phẩy" />
        </div>
        <div class="mb-3">
          <label class="form-label" for="hc_add_desc">Mô tả ngắn</label>
          <textarea name="desc" id="hc_add_desc" class="form-control" rows="3" placeholder="Mô tả hiển thị danh sách"></textarea>
        </div>
        <div class="mb-0">
          <label class="form-label" for="editor">Nội dung</label>
          <textarea name="content" id="editor" class="form-control">Nội dung bài viết…</textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border">
      <div class="card-header py-2 px-3 bg-body-secondary bg-opacity-10 border-bottom">
        <span class="small fw-semibold text-body-secondary">Thiết lập xuất bản</span>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label" for="category_root">Danh mục</label>
          <select name="" id="category_root" class="form-select">
            <option value="#">— Chọn danh mục —</option>
            <% if (menu) { %>
              <% menu.forEach((menu) => { %>
                <option value="<%= menu._id %>"><%= menu.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label" for="type">Đối tượng</label>
          <select name="" id="type" class="form-select">
            <option value="0">Customer</option>
            <option value="1">Technician</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label" for="status">Trạng thái</label>
          <select name="" id="status" class="form-select">
            <option value="0">Draft</option>
            <option value="1">Publish</option>
          </select>
        </div>
        <div class="mb-0">
          <label class="form-label">Ảnh đại diện</label>
          <div class="image_action admin-image-action-block">
            <div class="d-flex flex-wrap gap-2 mb-2">
              <button type="button" class="btn btn-outline-success btn-sm chooseImg flex-grow-1">Chọn ảnh từ gallery</button>
            </div>
            <input
              type="text"
              id="img_thumb"
              name="home_intro_img"
              value=""
              class="form-control form-control-sm img_input d-none"
              readonly
            />
            <div class="img_preview admin-img-preview rounded border bg-body-secondary d-flex align-items-center justify-content-center text-body-secondary small" style="min-height: 160px; max-height: 220px;">
              Chưa chọn ảnh
            </div>
          </div>
        </div>
        <ul id="sub_category_list" class="list-unstyled mt-2 mb-0 small"></ul>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/galleryPickerModal.ejs') %>

<script>
  tinymce.init({
    selector: '#editor',
    height: 480,
    license_key: 'gpl',
    plugins: 'lists link image code',
    toolbar: 'undo redo | bold italic | alignleft aligncenter alignright alignjustify | bullist numlist | code',
  });

  document.querySelector('#btn_create_blog').addEventListener('click', () => {
    const root = document.querySelector('#category_root').value;
    if (!root || root === '#') {
      alert('Vui lòng chọn danh mục');
      return;
    }
    const tagsInput = document.querySelector('#tags').value;
    const tagsArray = tagsInput.split(',').map((tag) => tag.trim()).filter((tag) => tag !== '');
    const payload = {
      category: root,
      title: document.querySelector('input[name="title"]').value,
      slug: document.querySelector('input[name="slug"]').value,
      desc: document.querySelector('textarea[name="desc"]').value,
      type: document.querySelector('#type').value,
      content: tinymce.get('editor').getContent(),
      status: document.querySelector('#status').value,
      img: document.querySelector('#img_thumb').value,
      tags: tagsArray,
    };
    submitData(payload);
  });

  function submitData(payload) {
    fetch('/admin/help-center/article/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
      .then((res) => res.json())
      .then((res) => {
        console.log(res);
        if (res.success) {
          myNotification('Đã tạo bài viết', 'success');
          window.location.href = '/admin/help-center/article';
        }
      })
      .catch((err) => {
        console.log(err);
        myNotification('Tạo bài thất bại', 'danger');
      });
  }

  function slugify(text) {
    return text
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/đ/g, 'd')
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  const titleInput = document.querySelector('input[name="title"]');
  const slugInput = document.querySelector('input[name="slug"]');
  titleInput.addEventListener('input', () => {
    slugInput.value = slugify(titleInput.value);
  });

  const chooseImgModal = document.querySelector('#gallery_modal');
  const ctaChooseImg = document.querySelectorAll('.chooseImg');
  let imgInputIsFocusing = null;

  function openChooseImgModal() {
    chooseImgModal.classList.remove('hidden');
    chooseImgModal.classList.add('flex');
  }
  function closeChooseImgModal() {
    chooseImgModal.classList.remove('flex');
    chooseImgModal.classList.add('hidden');
  }
  window.closeChooseImgModal = closeChooseImgModal;

  ctaChooseImg.forEach((el) => {
    el.addEventListener('click', (ev) => {
      ev.preventDefault();
      loadImage();
      imgInputIsFocusing = el.closest('.image_action');
      openChooseImgModal();
    });
  });

  function loadImage() {
    const imgList = document.querySelector('#imgList');
    if (!imgList) return;
    imgList.innerHTML = 'Loading...';
    $.ajax({
      url: '/admin/gallery/image-getall',
      method: 'GET',
      success: (res) => {
        if (res.success) {
          imgList.innerHTML = '';
          res.data.forEach((item) => {
            const img = document.createElement('img');
            img.src = '/' + item.path;
            img.className = 'admin-img-picker-item';
            img.onclick = () => selectImage(item.path);
            imgList.appendChild(img);
          });
        }
      },
      error: (xhr) => console.log(xhr.responseJSON?.mess || 'Server error'),
    });
  }

  function selectImage(src) {
    if (!imgInputIsFocusing) return;
    imgInputIsFocusing.querySelector('.img_input').value = src;
    const wrap = imgInputIsFocusing.querySelector('.img_preview');
    wrap.className = 'img_preview admin-img-preview rounded border bg-body-secondary';
    wrap.style.cssText = 'min-height: 160px; max-height: 220px; overflow: hidden;';
    wrap.innerHTML = '<img src="/' + src + '" alt="" class="w-100 h-100" style="object-fit: cover; max-height: 220px;" />';
    closeChooseImgModal();
  }
</script>
